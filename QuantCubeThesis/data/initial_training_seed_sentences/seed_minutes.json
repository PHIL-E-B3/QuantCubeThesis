    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "e5a63625-8806-47aa-9ee5-7f1416af2434",
    "sentence": "In the nonbank sector, leverage at hedge funds remained high, partly on account of the prevalence of the Treasury cash–futures basis trade.",
