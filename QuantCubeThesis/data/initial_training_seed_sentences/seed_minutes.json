    "ris": "",
    "wid": ""
  },
  {
    "id": "84aef93b-f21d-44c9-8599-73a94d27abef",
    "sentence": "Later in the intermeeting period, investment-grade bond issuance resumed intermittently, but speculative-grade issuance and leveraged loan issuance virtually stopped.",
    "source": "minutes_20200315.html",
    "doc_type": "minutes",
    "date": "20200315",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
