    "ris": "",
    "wid": ""
  },
  {
    "id": "bf37b00f-04d6-43c8-9a55-c3e3d1bdfc5d",
    "sentence": "Domestic and global financial conditions eased over the intermeeting period, the incoming news on the foreign economic outlook was generally positive, and investor sentiment improved.",
    "source": "minutes_20160427.html",
    "doc_type": "minutes",
    "date": "20160427",
    "context_question": null,
    "top": "",
    "sen": "",
