    "doc_type": "minutes",
    "date": "20180131",
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "cdf8dfba-169e-48f6-85f4-068d9d64e257",
    "sentence": "Total take-up of overnight and term reverse repurchase agreements at the end of the third quarter was also elevated.",
