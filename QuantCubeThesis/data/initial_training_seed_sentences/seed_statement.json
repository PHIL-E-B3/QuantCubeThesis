    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "7cf57804-7957-4f89-9ea5-4ab9da38e7d6",
    "sentence": "The Committee is attentive to the risks to both sides of its dual mandate and judges that downside risks to employment rose in recent months.",
    "source": "statement_20251210.txt",
    "doc_type": "statement",
    "date": "2025-12-10",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "5b61b610-0e13-4cf8-a300-7be473cff510",
    "sentence": "With substantial resource slack continuing to restrain cost pressures and longer-term inflation expectations stable, inflation is likely to be subdued for some time.",
    "source": "statement_20100623.txt",
    "doc_type": "statement",
    "date": "2010-06-23",
    "context_question": null,
    "top": "",
