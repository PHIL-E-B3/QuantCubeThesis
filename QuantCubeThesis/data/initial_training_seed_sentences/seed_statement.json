    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "e6432e09-6cf4-4fae-a275-e6800d0636fd",
    "sentence": "Against this backdrop, the Committee decided to maintain the target range for the federal funds rate at 1/4 to 1/2 percent.",
    "source": "statement_20161102.txt",
    "doc_type": "statement",
    "date": "2016-11-02",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
