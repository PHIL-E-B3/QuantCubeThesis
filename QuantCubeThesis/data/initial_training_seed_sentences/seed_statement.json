    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "09542adc-3dd4-4401-bd51-290af457e37a",
    "sentence": "The focus of the Committee's policy is to support the functioning of financial markets and stimulate the economy through open market operations and other measures that are likely to keep the size of the Federal Reserve's balance sheet at a high level.",
    "source": "statement_20090128.txt",
    "doc_type": "statement",
    "date": "2009-01-28",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "544e53a3-689c-4935-9d8c-8481ac4dddfc",
    "sentence": "Bank lending has continued to contract in recent months.",
    "source": "statement_20100623.txt",
    "doc_type": "statement",
    "date": "2010-06-23",
    "context_question": null,
