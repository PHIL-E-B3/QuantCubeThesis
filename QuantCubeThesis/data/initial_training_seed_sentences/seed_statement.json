    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "333e4208-b7d9-49b5-8df5-af5d9ee49706",
    "sentence": "The TSLF is intended to promote liquidity in the financing markets for Treasury and other collateral and thus to foster the functioning of financial markets more generally.",
    "source": "statement_20080311.txt",
    "doc_type": "statement",
    "date": "2008-03-11",
    "context_question": null,
