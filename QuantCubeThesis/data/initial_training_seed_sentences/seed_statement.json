    "ris": "",
    "wid": ""
  },
  {
    "id": "823880db-4040-46da-948b-4f8f5b4967c9",
    "sentence": "The Committee is attentive to the risks to both sides of its dual mandate and judges that the risks of higher unemployment and higher inflation have risen.",
    "source": "statement_20250507.txt",
    "doc_type": "statement",
    "date": "2025-05-07",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
