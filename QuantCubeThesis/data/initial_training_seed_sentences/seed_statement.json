    "wid": ""
  },
  {
    "id": "2820ad08-c54b-4444-9f0e-3a485bcbf50c",
    "sentence": "In light of the declines in the prices of energy and other commodities in recent months and the prospects for considerable economic slack, the Committee expects that inflation pressures will remain subdued in coming quarters.",
    "source": "statement_20090128.txt",
    "doc_type": "statement",
    "date": "2009-01-28",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
