    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "a69ae638-f31b-4b65-a8e6-4357d6795ecc",
    "sentence": "The Committee is maintaining its existing policy of reinvesting principal payments from its holdings of agency debt and agency mortgage-backed securities in agency mortgage-backed securities and of rolling over maturing Treasury securities at auction, and it anticipates doing so until normalization of the level of the federal funds rate is well under way. This policy, by keeping the Committee's holdings of longer-term securities at sizable levels, should help maintain accommodative financial conditions.",
    "source": "statement_20170503.txt",
    "doc_type": "statement",
    "date": "2017-05-03",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "5d2a236d-85d9-4606-bd53-ee38ae8032cf",
    "sentence": "Consistent with its statutory mandate, the Committee seeks to foster maximum employment and price stability.",
    "source": "statement_20160316.txt",
    "doc_type": "statement",
    "date": "2016-03-16",
    "context_question": null,
