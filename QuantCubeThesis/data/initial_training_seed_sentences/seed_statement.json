    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "ac7c6b26-3a98-4386-908a-3c4663a0c123",
    "sentence": "The Committee will continue to monitor the economic outlook and financial developments and is prepared to provide additional accommodation if needed to support the economic recovery and to return inflation, over time, to levels consistent with its mandate.",
    "source": "statement_20100921.txt",
    "doc_type": "statement",
    "date": "2010-09-21",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "249b8a23-8ea8-4606-a15d-de6db7cadf77",
    "sentence": "The Committee will maintain the target range for the federal funds rate at 0 to 1/4 percent and continues to anticipate that economic conditions, including low rates of resource utilization, subdued inflation trends, and stable inflation expectations, are likely to warrant exceptionally low levels of the federal funds rate for an extended period.",
    "source": "statement_20100623.txt",
    "doc_type": "statement",
    "date": "2010-06-23",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "180d2234-b896-4ecc-a7bd-fcb34afe6055",
    "sentence": "The Committee anticipates that inflation over the medium term will run at or below the rate that it judges most consistent with its dual mandate.",
    "source": "statement_20120801.txt",
    "doc_type": "statement",
    "date": "2012-08-01",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "71f89968-8dea-48fa-8c97-865cec4d2c2c",
    "sentence": "The economic outlook is uncertain, and the Committee is attentive to the risks to both sides of its dual mandate.",
    "source": "statement_20250129.txt",
    "doc_type": "statement",
    "date": "2025-01-29",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "4c87855b-cd23-425e-8dc5-9797375bb9ff",
    "sentence": "Uncertainty about the economic outlook has diminished but remains elevated.",
    "source": "statement_20250618.txt",
    "doc_type": "statement",
    "date": "2025-06-18",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "fd80e61a-1af5-4102-bd72-f1a271c3dfac",
    "sentence": "The Committee continues to view sustained expansion of economic activity, strong labor market conditions, and inflation near the Committee's symmetric 2 percent objective as the most likely outcomes, but uncertainties about this outlook have increased.",
    "source": "statement_20190619.txt",
    "doc_type": "statement",
    "date": "2019-06-19",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "5188cffc-7ae3-4d28-9728-4cb0394e7f42",
    "sentence": "The Committee will continue to assess the economic outlook in light of incoming information and is prepared to employ its tools to promote a stronger economic recovery in a context of price stability.",
    "source": "statement_20111213.txt",
    "doc_type": "statement",
    "date": "2011-12-13",
    "context_question": null,
