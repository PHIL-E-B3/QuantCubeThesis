    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "f699c87e-478b-450a-aa6a-ec8ecbc940fb",
    "sentence": "However, the Committee judges that some inflation risks remain, and it will continue to monitor inflation developments carefully.",
    "source": "statement_20070918.txt",
    "doc_type": "statement",
    "date": "2007-09-18",
    "context_question": null,
