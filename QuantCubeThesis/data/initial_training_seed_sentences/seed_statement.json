    "ris": "",
    "wid": ""
  },
  {
    "id": "925020f5-c07b-4dfc-a571-29a6ac2991a9",
    "sentence": "In view of realized and expected labor market conditions and inflation, the Committee decided to maintain the target range for the federal funds rate at 3/4 to 1 percent.",
    "source": "statement_20170503.txt",
    "doc_type": "statement",
    "date": "2017-05-03",
