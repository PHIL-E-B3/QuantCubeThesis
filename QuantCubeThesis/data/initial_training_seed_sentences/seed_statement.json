    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "c6b6b79b-0735-46d1-b891-6789eac2827f",
    "sentence": "Taking into account the extent of federal fiscal retrenchment since the inception of its current asset purchase program, the Committee continues to see the improvement in economic activity and labor market conditions over that period as consistent with growing underlying strength in the broader economy.",
    "source": "statement_20140129.txt",
    "doc_type": "statement",
    "date": "2014-01-29",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "f7b0cbf6-f914-4f54-b649-ca3033b73374",
    "sentence": "Moreover, there are significant downside risks to the economic outlook, including strains in global financial markets.",
    "source": "statement_20111102.txt",
    "doc_type": "statement",
    "date": "2011-11-02",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
