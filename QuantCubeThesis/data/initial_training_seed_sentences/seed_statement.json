    "ris": "",
    "wid": ""
  },
  {
    "id": "485b2af2-d986-4dd9-9a3d-25761ece34c4",
    "sentence": "In addition, given economic and financial conditions, Mr. Hoenig did not believe that keeping constant the size of the Federal Reserve's holdings of longer-term securities at their current level was required to support a return to the Committee's policy objectives.",
    "source": "statement_20100810.txt",
    "doc_type": "statement",
    "date": "2010-08-10",
    "context_question": null,
    "top": "",
    "ten": "",
