    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "1a3cd818-7188-4195-943a-28c0b43125da",
    "sentence": "Inflation has moved up since earlier in the year and remains somewhat elevated.",
    "source": "statement_20251210.txt",
    "doc_type": "statement",
    "date": "2025-12-10",
    "context_question": null,
    "top": "",
