    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "f254f125-5acd-4996-9dbc-7649bf3e091d",
    "sentence": "Beginning in February, the Committee will add to its holdings of agency mortgage-backed securities at a pace of $30 billion per month rather than $35 billion per month, and will add to its holdings of longer-term Treasury securities at a pace of $35 billion per month rather than $40 billion per month.",
    "source": "statement_20140129.txt",
    "doc_type": "statement",
    "date": "2014-01-29",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "b7cf1de1-7ec9-449e-93d0-ffcf51984945",
    "sentence": "The Committee does not expect it will be appropriate to reduce the target range until it has gained greater confidence that inflation is moving sustainably toward 2 percent.",
    "source": "statement_20240731.txt",
    "doc_type": "statement",
    "date": "2024-07-31",
    "context_question": null,
    "top": "",
