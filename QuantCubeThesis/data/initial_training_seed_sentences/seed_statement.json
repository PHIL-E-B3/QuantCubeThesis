  },
  {
    "id": "7feca26e-ad42-48a3-9976-8104ce411b6d",
    "sentence": "The Committee is strongly committed to returning inflation to its 2 percent objective.",
    "source": "statement_20240731.txt",
    "doc_type": "statement",
    "date": "2024-07-31",
    "context_question": null,
    "top": "",
    "ten": "",
