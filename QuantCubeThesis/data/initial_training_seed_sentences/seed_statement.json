    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "349f7845-209e-476e-b74e-c1452a489558",
    "sentence": "The Committee sees the risks to the outlook for the economy and the labor market as nearly balanced.",
    "source": "statement_20140618.txt",
    "doc_type": "statement",
    "date": "2014-06-18",
    "context_question": null,
