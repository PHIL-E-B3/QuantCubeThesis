    "doc_type": "press_conference_qa",
    "date": "20190501",
    "context_question": "Well, I mean, if it was an issue, would it be appropriate to lower rates if core inflation held closer to 1½ percent? And, if not, are you worried that there is unwanted tightening from real rates, being where they are?",
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
