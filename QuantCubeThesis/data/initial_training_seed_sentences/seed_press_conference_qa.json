  {
    "id": "704e31f5-5e5d-4c96-b7f6-3669952f972e",
    "sentence": "On the policy what?",
    "source": "FOMCpresconf20251210.json",
    "doc_type": "press_conference_qa",
    "date": "20251210",
    "context_question": "Thank you, Chair. Enda Curran, Bloomberg News. Given the breadth of views on the policy Committee, why is there such a division of views between the—",
