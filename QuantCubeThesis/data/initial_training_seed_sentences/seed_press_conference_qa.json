  {
    "id": "690ffcdd-f2d7-4225-8bc4-91a2511af8db",
    "sentence": "You've got companies in surveys saying that labor is scarce.",
    "source": "FOMCpresconf20190619.pdf",
    "doc_type": "press_conference_qa",
