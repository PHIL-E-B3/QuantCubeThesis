    "ris": "",
    "wid": ""
  },
  {
    "id": "a615814b-dd10-4990-8c7a-51965e1dcc71",
    "sentence": "I do not think that they're perfect.",
    "source": "FOMCpresconf20151216.pdf",
    "doc_type": "press_conference_qa",
    "date": "20151216",
    "context_question": "You have a background as an academic. Are you looking into these models to see whether they need to be adapted?",
    "top": "",
    "sen": "",
