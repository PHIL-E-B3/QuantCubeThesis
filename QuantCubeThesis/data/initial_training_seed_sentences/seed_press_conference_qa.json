  {
    "id": "1e3a216a-d0a1-4beb-8d12-ae49da9d061d",
    "sentence": "You know, the, the real economy, the, the hard data are still in, in reasonably good shape.",
    "source": "FOMCpresconf20250319.json",
    "doc_type": "press_conference_qa",
