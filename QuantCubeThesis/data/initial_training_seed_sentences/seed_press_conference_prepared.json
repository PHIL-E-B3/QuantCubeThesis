    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "0f5c6236-78b2-4134-978a-86e32614d62a",
    "sentence": "We will need to see more good data to bolster our confidence that inflation is moving sustainably toward 2 percent.",
    "source": "FOMCpresconf20240612.json",
    "doc_type": "press_conference_prepared",
    "date": "20240612",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
