    "ris": "",
    "wid": ""
  },
  {
    "id": "b636e8a7-a8c6-4f73-b2fe-39072693ec2c",
    "sentence": "At today's meeting, the Committee also decided to conclude the reduction of our aggregate securities holdings as of December 1.",
    "source": "FOMCpresconf20251029.json",
    "doc_type": "press_conference_prepared",
    "date": "20251029",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "8aaae81c-6eca-41dc-a395-bdb3fceba3ab",
    "sentence": "As I mentioned, the current level of the federal funds rate target is likely to remain appropriate for a considerable period after asset purchases are concluded.",
    "source": "FOMCpresconf20130619.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20130619",
    "context_question": null,
    "top": "",
    "sen": "",
