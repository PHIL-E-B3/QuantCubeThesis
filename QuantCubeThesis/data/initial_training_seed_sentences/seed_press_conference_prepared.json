  {
    "id": "89036616-ef3a-46c9-b318-f15f91e1fd76",
    "sentence": "The median projection in the SEP for total PCE inflation is 2.4 percent this year and 2.5 percent next year, somewhat higher than projected in September.",
    "source": "FOMCpresconf20241218.json",
    "doc_type": "press_conference_prepared",
