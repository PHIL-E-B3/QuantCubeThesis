    "wid": ""
  },
  {
    "id": "c606aa16-f1f5-40c9-86d2-45944d0bef65",
    "sentence": "In addition, the median estimate of the longer-run normal unemployment rate moved down a tenth to 4.6 percent.",
    "source": "FOMCpresconf20170614.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20170614",
