    "wid": ""
  },
  {
    "id": "659277b3-afde-4346-b499-27fe270adeb6",
    "sentence": "With many FOMC participants now projecting that the 6½ percent unemployment threshold will be reached by the end of 2014, the Committee decided to provide additional information about how it expects its policies to evolve after the threshold is crossed.",
    "source": "FOMCpresconf20131218.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20131218",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "8408d282-11b6-49dc-84ef-19ac332338f9",
    "sentence": "The economic dislocation has upended many lives and created great uncertainty about the future.",
    "source": "FOMCpresconf20210428.json",
    "doc_type": "press_conference_prepared",
    "date": "20210428",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
