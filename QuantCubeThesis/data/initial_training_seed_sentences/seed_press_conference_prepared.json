  {
    "id": "a577a59b-f30f-4d2b-b630-71b3fba7da58",
    "sentence": "Recent indications, however, point to a moderation in consumer spending following the rapid growth seen over the second half of 2024.",
    "source": "FOMCpresconf20250319.json",
    "doc_type": "press_conference_prepared",
    "date": "20250319",
