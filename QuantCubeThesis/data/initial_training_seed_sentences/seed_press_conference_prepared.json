    "ris": "",
    "wid": ""
  },
  {
    "id": "3221fd48-5cf8-4061-bd8d-3a0a9cbd9593",
    "sentence": "Although there has been much progress in the labor market since the spring, millions of Americans remain out of work.",
    "source": "FOMCpresconf20210127.json",
    "doc_type": "press_conference_prepared",
    "date": "20210127",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "3bd43581-6710-424b-8d67-3ac0ccd06afe",
    "sentence": "Consumer spending appears to have picked up this quarter, although some of that strength may reflect the effects of swings in the weather across the turn of the year.",
    "source": "FOMCpresconf20230322.json",
    "doc_type": "press_conference_prepared",
