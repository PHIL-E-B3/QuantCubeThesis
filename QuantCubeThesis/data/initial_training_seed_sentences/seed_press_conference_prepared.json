  {
    "id": "1c1215c2-f99b-45ff-a318-7f2decd092c9",
    "sentence": "So it is conceivable but quite unlikely that it could happen.",
    "source": "FOMCpresconf20160615.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20160615",
    "context_question": null,
    "top": "",
