  },
  {
    "id": "785751b6-a87c-4cb8-b819-531cf2e3a752",
    "sentence": "The unemployment rate, at 4.2 percent, remains low and has stayed in a narrow range for the past year.",
    "source": "FOMCpresconf20250618.json",
    "doc_type": "press_conference_prepared",
    "date": "20250618",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
