  {
    "id": "66912195-12d9-40e1-ad32-a8548b6e9e01",
    "sentence": "As I have noted, the baseline economic outlook remains positive.",
    "source": "FOMCpresconf20190918.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20190918",
    "context_question": null,
