    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "fe481bc9-0f6c-4b36-bfa7-e8f08507a14d",
    "sentence": "Let me now turn to the framework we will be applying as we consider interest rate policy.",
    "source": "FOMCpresconf20140618.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20140618",
