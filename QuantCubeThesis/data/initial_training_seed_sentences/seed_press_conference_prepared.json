    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "886b0965-6819-46da-ace4-6241bb85d5e5",
    "sentence": "We know that reducing policy restraint too quickly could hinder progress on inflation.",
    "source": "FOMCpresconf20240918.json",
    "doc_type": "press_conference_prepared",
    "date": "20240918",
    "context_question": null,
    "top": "",
