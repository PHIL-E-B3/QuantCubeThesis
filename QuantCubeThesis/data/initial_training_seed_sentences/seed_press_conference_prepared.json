  {
    "id": "489a98a8-189c-49b1-a1ee-cba0e92b6aeb",
    "sentence": "We decided to keep the target range for the federal funds rate at 0 to ¼ percent, and we continue to anticipate that economic conditions are likely to warrant exceptionally low levels of the federal funds rate at least through late 2014.",
    "source": "FOMCpresconf20120620.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20120620",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "7857d780-af6d-436b-8bad-f728881dd7c3",
    "sentence": "As part of normalization, we will have to decide what the maturity structure should be in the longer term.",
    "source": "FOMCpresconf20190501.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20190501",
    "context_question": null,
    "top": "",
