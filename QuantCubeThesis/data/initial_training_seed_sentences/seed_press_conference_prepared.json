    "wid": ""
  },
  {
    "id": "bced070c-431e-493c-b782-ea86f40b23af",
    "sentence": "Since the middle of last year, the global growth outlook has weakened, notably in Europe and China.",
    "source": "FOMCpresconf20190918.pdf",
    "doc_type": "press_conference_prepared",
    "date": "20190918",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
