    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "15f22118-b78a-4083-88e8-7a82bb796677",
    "sentence": "This reform thread is sourced in the Dodd-Frank requirement for stress testing at large banks, but more generally in the Federal Reserve's establishment of a formal annual capital planning requirement for these firms.",
    "source": "The Evolution of Capital Regulation",
    "doc_type": "speech",
