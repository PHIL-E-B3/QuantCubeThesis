    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "22719255-8d36-4d22-bf95-c3fa0d9704dd",
    "sentence": "We found that loans originated under the NWA program had a lower delinquency rate than subprime loans.",
    "source": "The Community Reinvestment Act and the Recent Mortgage Crisis",
    "doc_type": "speech",
    "date": "2008-12-03",
