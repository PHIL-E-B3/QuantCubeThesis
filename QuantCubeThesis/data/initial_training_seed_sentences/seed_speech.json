    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "2c4fa31a-8d9e-4035-aa62-9beb31f95054",
    "sentence": "If anything, some measures of longer-term inflation expectations in the United States have edged lower in recent years.",
    "source": "Monetary Policy at a Time of Uncertainty and Tight Labor Markets",
    "doc_type": "speech",
    "date": "2018-06-20",
    "context_question": null,
    "top": "",
