  },
  {
    "id": "2e8884dc-f0fc-4f2c-905d-e3ae6409d742",
    "sentence": "There are a couple of ways to respond to bank concerns without courting these dangers.",
    "source": "Departing Thoughts",
    "doc_type": "speech",
    "date": "2017-04-04",
    "context_question": null,
