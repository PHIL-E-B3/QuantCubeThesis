    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "505ae0dc-99ea-48b1-8545-809749904557",
    "sentence": "As a part of this approach, I have also prioritized efforts to improve the consistency, transparency, and reasonableness of regulation and supervision.",
    "source": "My Perspective on Bank Regulation and Supervision",
    "doc_type": "speech",
    "date": "2021-02-16",
