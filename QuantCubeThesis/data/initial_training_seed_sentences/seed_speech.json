    "ris": "",
    "wid": ""
  },
  {
    "id": "4fb3589d-5f07-4fce-94c6-a9214a357189",
    "sentence": "To those ends, we have lowered interest rates to near zero in order to bring down borrowing costs.",
    "source": "COVID-19 and the Economy",
    "doc_type": "speech",
    "date": "2020-04-09",
    "context_question": null,
