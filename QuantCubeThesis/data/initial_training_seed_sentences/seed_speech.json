    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "c181350a-4f99-450f-893b-a8252c912f98",
    "sentence": "Like other countries, we are taking forceful measures to control the spread of the virus.",
    "source": "COVID-19 and the Economy",
    "doc_type": "speech",
    "date": "2020-04-09",
    "context_question": null,
