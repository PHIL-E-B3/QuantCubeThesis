    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "9e007d1c-1090-495a-807b-016de304ed1f",
    "sentence": "After any special topics or briefings, the discussion turns to the economy.",
    "source": "Come with Me to the FOMC",
    "doc_type": "speech",
    "date": "2010-10-19",
    "context_question": null,
    "top": "",
    "sen": "",
