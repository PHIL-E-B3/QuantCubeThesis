    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "a8916b70-be95-4ecb-b50c-17dc37ce6287",
    "sentence": "Elevated goods inflation has contributed significantly to a stalling in the disinflationary process.",
    "source": "Brief Remarks on the Economic Outlook and Monetary Policy",
    "doc_type": "speech",
    "date": "2026-03-26",
