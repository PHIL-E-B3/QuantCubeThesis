  },
  {
    "id": "f73e1663-9758-4e3f-bf52-e2ec3504b61a",
    "sentence": "Your chances for attending college are much better if you are raised in a higher-income household, and that advantage has increased substantially since the 1980s.",
    "source": "Welcoming Remarks",
    "doc_type": "speech",
