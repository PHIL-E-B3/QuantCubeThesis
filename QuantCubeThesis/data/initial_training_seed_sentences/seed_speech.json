    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "a145663a-8d0a-4d02-ada6-c32674d36473",
    "sentence": "Stablecoin issuers suggest that one can redeem a stablecoin from the issuer for one U.S. dollar, although redemption rights are not always well defined.",
    "source": "Reflections on Stablecoins and Payments Innovations",
    "doc_type": "speech",
