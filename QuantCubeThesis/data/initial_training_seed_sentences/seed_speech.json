    "wid": ""
  },
  {
    "id": "91c8b80e-28d7-48d8-89a5-f53f6821f634",
    "sentence": "Macroprudential policies focus on risks to the financial system as a whole. Such risks may be crosscutting, affecting a number of firms and markets, or they may be concentrated in a few key areas.",
    "source": "Financial Reform to Address Systemic Risk",
    "doc_type": "speech",
    "date": "2009-03-10",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "23c21362-4693-450a-965a-690068b2d20c",
    "sentence": "Our net income will soon turn positive again, as it typically has been throughout our history.",
    "source": "Understanding the Fedâs Balance Sheet",
    "doc_type": "speech",
    "date": "2025-10-14",
    "context_question": null,
