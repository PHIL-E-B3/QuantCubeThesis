    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "7e9a03f6-cd87-4377-9ee5-feaf8bc6aa26",
    "sentence": "Among the aspirations that each of you hold as you leave the Greek theater today, I hope that you will use what you have learned at Berkeley to be part of this fight.",
    "source": "Commencement Remarks",
    "doc_type": "speech",
    "date": "2025-05-20",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "55a6ed2b-f0b2-4813-879e-3c818dafb880",
    "sentence": "Notwithstanding these welcome recent signs, the job market remains quite weak relative to historical norms, as I've already noted.",
    "source": "Recent Developments in the Labor Market",
    "doc_type": "speech",
    "date": "2012-03-26",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "52aae40e-93d0-42b3-bb31-6a80ac6b2005",
    "sentence": "Technological developments appear to be rapidly reshaping entire industriesââin retail, transportation, and communications.",
    "source": "The Low Level of Global Real Interest Rates",
    "doc_type": "speech",
