    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "2d7333d1-54e6-4403-8f07-1d77e1741256",
    "sentence": "Our influence on the financial conditions that affect employment and inflation is indirect.",
    "source": "Data-Dependent Monetary Policy in an Evolving Economy",
    "doc_type": "speech",
    "date": "2019-10-08",
    "context_question": null,
    "top": "",
    "sen": "",
    "ten": "",
