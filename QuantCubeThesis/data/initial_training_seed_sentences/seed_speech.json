    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "77c609e4-fd84-452a-a6b2-ac17e4fb8cd0",
    "sentence": "I expect that ongoing increases will be appropriate to bring the federal funds rate to a sufficiently restrictive level and that it will need to remain there for some time to restore price stability.",
    "source": "Independence, Predictability, and Tailoring in Banking Regulation and Supervision",
    "doc_type": "speech",
