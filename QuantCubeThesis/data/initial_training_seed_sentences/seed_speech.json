    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "6dc0b4a5-627f-4e41-a195-80c007115da6",
    "sentence": "And many of the largest banks are also clearing members, which introduces a certain amount of wrong-way risk.",
    "source": "Central Clearing and Liquidity",
    "doc_type": "speech",
    "date": "2017-06-23",
    "context_question": null,
    "top": "",
