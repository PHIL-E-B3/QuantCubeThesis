    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "c382870c-7405-4a74-8a10-8b3c6e3b2dac",
    "sentence": "In short, where the financial regulatory framework can provide for parity of treatment, it should do so.",
    "source": "Challenges to the Community Banking Model",
    "doc_type": "speech",
    "date": "2024-10-11",
    "context_question": null,
