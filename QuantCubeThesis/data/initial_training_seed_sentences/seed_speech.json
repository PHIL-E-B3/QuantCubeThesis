    "sen": "",
    "dir": "",
    "com": "",
    "hor": "",
    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "fd3056f1-b58f-4bdf-84ef-fb7099485ba7",
    "sentence": "This price-based approach creates some incentive for all three banks to shrink, but lets them balance this incentive against the scale benefits that they realize by staying big.",
    "source": "Regulating Large Financial Institutions",
    "doc_type": "speech",
    "date": "2013-04-17",
