    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "13f65ebf-567e-48f3-94f4-a43198a64089",
    "sentence": "Indeed, it is noteworthy that most community banks adhering to this model continued to thrive even during the worst years of the financial crisis.",
    "source": "Tailoring Community Bank Regulation and Supervision",
    "doc_type": "speech",
    "date": "2015-04-30",
