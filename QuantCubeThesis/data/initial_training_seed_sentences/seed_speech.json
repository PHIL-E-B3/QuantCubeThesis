    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "74e054c5-fb9e-404c-85e9-be8ebef42901",
    "sentence": "Bad actors might try to steal CBDC, compromise the CBDC network, or target non-public information about holders of CBDC.",
    "source": "Parachute Pants and Central Bank Money",
