    "hor": "",
    "com": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "84f7b23b-912d-44d0-8050-e0c6b67cbeea",
    "sentence": "Recognizing that there has been a dearth of MDI research in recent decades, last year, for the first time, we commissioned two external researchers to develop papers on MDIs.",
    "source": "Labor Market Disparities and Economic Performance",
    "doc_type": "speech",
