    "ris": "",
    "wid": ""
  },
  {
    "id": "4698cefb-7a47-452d-883c-4f0cb13d0043",
    "sentence": "In this process, we of course especially welcome the views of those of you on the front lines of insurance supervision.",
    "source": "Insurance Companies and the Role of the Federal Reserve",
    "doc_type": "speech",
    "date": "2016-05-20",
    "context_question": null,
