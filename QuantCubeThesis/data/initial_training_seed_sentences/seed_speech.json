  },
  {
    "id": "5abdd651-855d-46f5-91cf-1eaf23aa55ab",
    "sentence": "Will the Asset Purchase Program Result in Adverse Financial Imbalances?",
    "source": "The Federal Reserve's Asset Purchase Program",
