    "con": "",
    "dom": "",
    "ris": "",
    "wid": ""
  },
  {
    "id": "828fe086-fd71-4a17-be70-bb4370254577",
    "sentence": "Manufacturing output declined in April.",
    "source": "Economic Outlook ",
    "doc_type": "speech",
    "date": "2025-06-03",
    "context_question": null,
    "top": "",
    "ten": "",
    "sen": "",
